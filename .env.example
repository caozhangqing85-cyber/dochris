# ============================================================
# 知识库系统配置文件
# ============================================================
# 复制此文件为 .env 并根据实际环境修改配置值
# 配置优先级: .env 文件 > 环境变量 > 默认值

# ============================================================
# LLM API 配置（必需）
# ============================================================
# 获取 API Key: https://open.bigmodel.cn/
OPENAI_API_KEY=your_api_key_here
OPENAI_API_BASE=https://open.bigmodel.cn/api/coding/paas/v4
MODEL=glm-5.1

# 备用: OpenRouter (免费模型)
# OPENAI_API_BASE=https://openrouter.ai/api/v1
# MODEL=qwen/qwen-2.5-72b-instruct:free

# 本地 LLM 配置（可选，用于备用通道）
#LOCAL_LLM_BASE_URL=http://localhost:11434/v1
#LOCAL_LLM_MODEL=qwen:14b
#LOCAL_LLM_API_KEY=ollama

# ============================================================
# 工作区配置
# ============================================================
# 工作区路径（默认: ~/.knowledge-base）
# 可设置为绝对路径或 ~ 开头的路径
WORKSPACE=~/.knowledge-base

# ============================================================
# Phase 1: 数据摄入配置
# ============================================================
# 源文件扫描路径（可选）
# 用于扫描指定目录下的文件并创建符号链接到 raw/
SOURCE_PATH=/path/to/your/materials

# Obsidian vault 路径（可选）
# 单个路径
OBSIDIAN_VAULT=~/Documents/Obsidian-Sync
# 多个路径用冒号分隔
# OBSIDIAN_VAULTS=~/Documents/Obsidian-Sync:~/Another/Vault

# 最大文件大小（字节，默认 500MB）
# MAX_FILE_SIZE=524288000

# ============================================================
# Phase 2: 编译配置
# ============================================================
# 并发数（默认 3）
MAX_CONCURRENCY=3

# 批处理大小（默认 10）
BATCH_SIZE=10

# 质量评分门槛（默认 85）
MIN_QUALITY_SCORE=85

# 单文件最大字符数（默认 20000）
MAX_CONTENT_CHARS=20000

# ============================================================
# Phase 3: 查询配置
# ============================================================
# 查询专用模型（默认 glm-4-flash，更快的推理）
QUERY_MODEL=glm-4-flash

# 向量嵌入模型（用于语义搜索）
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# ============================================================
# 日志配置
# ============================================================
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================
# 缓存配置
# ============================================================
# 缓存保留天数（默认 30）
CACHE_RETENTION_DAYS=30

# ============================================================
# 重试配置
# ============================================================
# 最大重试次数（默认 3）
MAX_RETRIES=3

# 429 错误初始延迟（秒，默认 20）
# RETRY_DELAY_429=20

# 连接错误初始延迟（秒，默认 15）
# RETRY_DELAY_CONNECTION=15

# 一般错误初始延迟（秒，默认 10）
# RETRY_DELAY_GENERAL=10

# ============================================================
# 其他配置
# ============================================================
# LLM 温度参数（默认 0.1，越低越稳定）
# LLM_TEMPERATURE=0.1

# LLM 最大 token 数（默认 40000）
# LLM_MAX_TOKENS=40000

# LLM 请求超时（秒，默认 300）
# LLM_TIMEOUT=300

# LLM 请求间隔（秒，默认 5）
# LLM_REQUEST_DELAY=5

# 最大重试次数（默认 3）
# MAX_RETRIES=3
